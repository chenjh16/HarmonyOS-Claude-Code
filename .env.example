# Claude Code for HarmonyOS PC — Environment Variables
#
# This file is installed to ~/.claude/.env.example during npm postinstall.
# To configure: cp ~/.claude/.env.example ~/.claude/.env
# Then edit ~/.claude/.env with your actual values.
#
# start-claude.sh automatically sources ~/.claude/.env at startup.

# LiteLLM API key
ANTHROPIC_API_KEY=sk-your-litellm-api-key-here

# LiteLLM proxy endpoint
ANTHROPIC_BASE_URL=http://your-litellm-host:10380

# Models
ANTHROPIC_MODEL=GLM-5
ANTHROPIC_SMALL_FAST_MODEL=Qwen3.6-Plus
